# PKM Wiki - Caddy 反向代理配置
# 开发/临时模式：HTTP only，配合 Cloudflare Tunnel 使用

:80 {
    # API 请求 → FastAPI 后端
    handle /api/* {
        reverse_proxy api:8000
    }

    # 其他请求 → React 前端
    handle {
        reverse_proxy web:5173
    }
}

# 生产模式（直接暴露域名，Caddy 自动 HTTPS）
# 取消注释并设置 DOMAIN 环境变量
#
# {$DOMAIN:wiki.example.com} {
#     handle /api/* {
#         reverse_proxy api:8000
#     }
#     handle {
#         reverse_proxy web:5173
#     }
# }
